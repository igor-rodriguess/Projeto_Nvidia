# Variáveis de ambiente — NVIDIA Startup AI Radar (Frontend)

# Deixe vazio no desenvolvimento para usar o proxy do Vite.
# Em producao, informe a URL publica da API FastAPI (sem trailing slash).
VITE_API_BASE_URL=

# Supabase — obtenha em: https://app.supabase.com/project/<seu-projeto>/settings/api
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_publica

# Modo de autenticação: "supabase" (padrão) ou "apikey" (dev/fallback)
VITE_AUTH_MODE=supabase

# Chave de API legada (somente para desenvolvimento local com ALLOW_LEGACY_API_KEY=true no backend)
# VITE_DEV_API_KEY=gere-uma-chave-longa-e-aleatoria
