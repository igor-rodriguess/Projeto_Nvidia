  "additionalProperties": true,
  "properties": {
    "startup": {
      "title": "Startup",
      "type": "string"
    },
    "status": {
      "enum": [
        "completo",
        "parcial",
        "falha"
      ],
      "title": "Status",
      "type": "string"
    },
    "classificacao": {
      "anyOf": [
        {
          "enum": [
            "AI-native",
            "AI-enabled",
            "API-consumer",
            "Non-AI"
          ],
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Classificacao"
    },
    "nivel_maturidade": {
      "anyOf": [
        {
          "maximum": 5,
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Nivel Maturidade"
    },
    "recomendacao": {
      "anyOf": [
        {
          "$ref": "#/$defs/NVIDIARecommendationOutput"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "recomendacao_refinada": {
      "anyOf": [
        {
          "$ref": "#/$defs/RecommendationRefinementOutput"
        },
        {
          "type": "null"
        }
      ],
      "default": null
