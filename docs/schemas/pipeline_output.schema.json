    "briefing_markdown": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Briefing Markdown"
    },
    "pipeline_run_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Pipeline Run Id"
    },
    "trace": {
      "additionalProperties": {
        "$ref": "#/$defs/StageTrace"
      },
      "title": "Trace",
      "type": "object"
    },
    "errors": {
      "items": {
        "type": "string"
      },
      "title": "Errors",
      "type": "array"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    },
    "source_errors": {
      "items": {
        "type": "string"
      },
      "title": "Source Errors",
      "type": "array"
    },
    "critical_errors": {
      "items": {
        "type": "string"
      },
      "title": "Critical Errors",
      "type": "array"
    }
  },
  "required": [
    "startup",
    "status",
    "trace"
  ],
  "title": "PipelineOutput",
  "type": "object"
}
