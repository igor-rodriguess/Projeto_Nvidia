          "default": null,
          "title": "Output"
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error"
        },
        "warnings": {
          "items": {
            "type": "string"
          },
          "title": "Warnings",
          "type": "array"
        }
      },
      "required": [
        "status",
        "duration_ms",
        "attempts"
      ],
      "title": "StageTrace",
      "type": "object"
    },
    "TechnicalImpact": {
