        "fit_score": {
          "maximum": 1,
          "minimum": 0,
          "title": "Fit Score",
          "type": "number"
        },
        "alertas": {
          "items": {
            "type": "string"
          },
          "title": "Alertas",
          "type": "array"
        },
        "perguntas_startup": {
          "items": {
            "type": "string"
          },
          "title": "Perguntas Startup",
          "type": "array"
        }
      },
      "required": [
        "roadmap",
        "fit_score"
      ],
      "title": "RefinedRecommendation",
      "type": "object"
    },
    "RetrievedChunk": {
      "additionalProperties": true,
      "properties": {
        "chunk_id": {
          "minLength": 1,
          "title": "Chunk Id",
          "type": "string"
        },
        "content": {
          "minLength": 1,
          "title": "Content",
          "type": "string"
        },
        "metadata": {
          "$ref": "#/$defs/KnowledgeMetadata"
        },
        "retrieval_score": {
          "title": "Retrieval Score",
          "type": "number"
        },
        "rerank_score": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rerank Score"
        }
      },
      "required": [
        "chunk_id",
        "content",
        "metadata",
        "retrieval_score"
