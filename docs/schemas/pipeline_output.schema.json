    "RoadmapPhase": {
      "additionalProperties": true,
      "properties": {
        "tecnologias": {
          "items": {
            "enum": [
              "NIM",
              "Triton",
              "TensorRT-LLM",
              "NeMo",
              "RAPIDS",
              "CUDA",
              "Riva",
              "Omniverse",
              "Clara",
              "Isaac",
              "Morpheus",
              "AI Enterprise",
              "Inception"
