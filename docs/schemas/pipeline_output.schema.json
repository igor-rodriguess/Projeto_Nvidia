{
  "$defs": {
    "ImpactEstimationOutput": {
      "additionalProperties": true,
      "properties": {
        "startup": {
          "minLength": 1,
          "title": "Startup",
          "type": "string"
        },
        "estimativas_impacto": {
          "items": {
            "$ref": "#/$defs/TechnologyImpactEstimate"
          },
          "title": "Estimativas Impacto",
          "type": "array"
        },
        "indice_impacto_agregado": {
          "maximum": 100,
          "minimum": 0,
          "title": "Indice Impacto Agregado",
          "type": "integer"
        },
        "kpis_sugeridos": {
          "items": {
            "type": "string"
          },
          "title": "Kpis Sugeridos",
          "type": "array"
        },
        "incertezas": {
          "items": {
            "type": "string"
          },
          "title": "Incertezas",
          "type": "array"
        },
        "resumo_executivo": {
          "minLength": 1,
          "title": "Resumo Executivo",
          "type": "string"
        }
      },
      "required": [
        "startup",
        "indice_impacto_agregado",
        "resumo_executivo"
      ],
      "title": "ImpactEstimationOutput",
      "type": "object"
    },
    "KnowledgeMetadata": {
      "additionalProperties": true,
      "properties": {
        "tecnologia": {
          "enum": [
            "NIM",
            "Triton",
            "TensorRT-LLM",
            "NeMo",
            "RAPIDS",
            "CUDA",
            "Riva",
            "Omniverse",
            "Clara",
            "Isaac",
            "Morpheus",
            "AI Enterprise",
            "Inception"
          ],
          "title": "Tecnologia",
          "type": "string"
        },
        "tipo": {
          "enum": [
            "documentacao",
            "whitepaper",
            "blog",
            "case_study",
            "github"
          ],
          "title": "Tipo",
          "type": "string"
        },
        "dores_relacionadas": {
          "items": {
            "enum": [
              "custo",
              "latencia",
              "escalabilidade",
              "governanca",
              "privacidade",
              "vendor_lockin"
            ],
            "type": "string"
          },
          "title": "Dores Relacionadas",
          "type": "array"
        },
        "perfil_aplicavel": {
          "items": {
            "enum": [
              "AI-native",
              "AI-enabled",
              "API-consumer"
            ],
            "type": "string"
          },
          "title": "Perfil Aplicavel",
          "type": "array"
        },
        "titulo_secao": {
          "minLength": 1,
          "title": "Titulo Secao",
          "type": "string"
        },
        "url_fonte": {
          "title": "Url Fonte",
          "type": "string"
        }
      },
      "required": [
        "tecnologia",
        "tipo",
        "perfil_aplicavel",
        "titulo_secao",
        "url_fonte"
      ],
      "title": "KnowledgeMetadata",
      "type": "object"
    },
    "NVIDIARecommendationOutput": {
      "additionalProperties": true,
      "properties": {
        "startup": {
          "minLength": 1,
          "title": "Startup",
          "type": "string"
        },
        "recomendacoes": {
          "items": {
            "$ref": "#/$defs/RecommendationItem"
          },
          "title": "Recomendacoes",
          "type": "array"
        },
        "chunks_utilizados": {
          "items": {
            "$ref": "#/$defs/RetrievedChunk"
          },
          "maxItems": 5,
          "title": "Chunks Utilizados",
          "type": "array"
        },
        "aviso": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Aviso"
        }
      },
      "required": [
        "startup"
      ],
      "title": "NVIDIARecommendationOutput",
      "type": "object"
    },
    "PrioritizedTechnology": {
      "additionalProperties": true,
      "properties": {
        "tecnologia": {
          "enum": [
            "NIM",
            "Triton",
            "TensorRT-LLM",
            "NeMo",
            "RAPIDS",
            "CUDA",
            "Riva",
            "Omniverse",
            "Clara",
            "Isaac",
            "Morpheus",
            "AI Enterprise",
            "Inception"
          ],
          "title": "Tecnologia",
          "type": "string"
        },
        "ordem": {
          "minimum": 1,
