      "required": [
        "tecnologia",
        "fit_score",
        "justificativa",
        "citacoes"
      ],
      "title": "RecommendationItem",
      "type": "object"
    },
    "RecommendationRefinementOutput": {
      "additionalProperties": true,
      "properties": {
        "startup": {
          "minLength": 1,
          "title": "Startup",
          "type": "string"
        },
        "recomendacao_refinada": {
          "$ref": "#/$defs/RefinedRecommendation"
        }
      },
      "required": [
        "startup",
        "recomendacao_refinada"
      ],
      "title": "RecommendationRefinementOutput",
      "type": "object"
    },
    "RefinedRecommendation": {
      "additionalProperties": true,
      "properties": {
        "tecnologias_priorizadas": {
          "items": {
            "$ref": "#/$defs/PrioritizedTechnology"
