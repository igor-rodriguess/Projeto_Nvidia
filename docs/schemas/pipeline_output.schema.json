            "type": "string"
          },
          "title": "Tecnologias",
          "type": "array"
        },
        "acoes": {
          "items": {
            "type": "string"
          },
          "title": "Acoes",
          "type": "array"
        }
      },
      "title": "RoadmapPhase",
      "type": "object"
    },
    "StageTrace": {
      "additionalProperties": true,
      "properties": {
        "status": {
          "enum": [
            "completo",
            "cache",
            "parcial",
            "falha"
          ],
          "title": "Status",
          "type": "string"
        },
        "duration_ms": {
          "minimum": 0,
          "title": "Duration Ms",
          "type": "number"
        },
        "attempts": {
          "minimum": 0,
          "title": "Attempts",
          "type": "integer"
        },
        "tokens_consumidos": {
          "default": 0,
          "minimum": 0,
          "title": "Tokens Consumidos",
          "type": "integer"
