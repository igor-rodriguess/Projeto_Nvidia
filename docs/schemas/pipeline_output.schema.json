        },
        "beneficio": {
          "minLength": 1,
          "title": "Beneficio",
          "type": "string"
        },
        "dependencias": {
          "items": {
            "type": "string"
          },
          "title": "Dependencias",
          "type": "array"
        },
        "riscos": {
          "minLength": 1,
          "title": "Riscos",
          "type": "string"
        },
        "complexidade": {
          "enum": [
            "baixa",
            "media",
            "alta"
          ],
          "title": "Complexidade",
          "type": "string"
        },
        "fontes_evidencia": {
          "items": {
            "type": "string"
          },
          "title": "Fontes Evidencia",
          "type": "array"
        }
      },
      "required": [
        "tecnologia",
        "ordem",
        "fase",
        "problema_resolvido",
        "beneficio",
        "riscos",
        "complexidade"
