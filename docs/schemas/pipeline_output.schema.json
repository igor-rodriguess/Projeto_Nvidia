    "RecommendationItem": {
      "additionalProperties": true,
      "properties": {
        "tecnologia": {
          "enum": [
            "NIM",
            "Triton",
            "TensorRT-LLM",
            "NeMo",
            "RAPIDS",
            "CUDA",
            "Riva",
            "Omniverse",
            "Clara",
            "Isaac",
            "Morpheus",
            "AI Enterprise",
            "Inception"
          ],
          "title": "Tecnologia",
          "type": "string"
        },
        "fit_score": {
          "maximum": 1,
          "minimum": 0,
          "title": "Fit Score",
          "type": "number"
        },
        "justificativa": {
          "minLength": 1,
          "title": "Justificativa",
          "type": "string"
        },
        "dores_atendidas": {
          "items": {
            "type": "string"
          },
          "title": "Dores Atendidas",
          "type": "array"
        },
        "citacoes": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Citacoes",
          "type": "array"
