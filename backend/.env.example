SEARCH_PROVIDER=searxng
SEARXNG_BASE_URL=http://localhost:8080

# Opcional: Firecrawl extrai páginas modernas em Markdown.
# Também pode ser usado como provedor de busca.
# FIRECRAWL_API_KEY=sua_chave_firecrawl
# SEARCH_PROVIDER=firecrawl

# Alternativa gratuita sem Docker, menos estável que SearXNG local.
# SEARCH_PROVIDER=ddgs
