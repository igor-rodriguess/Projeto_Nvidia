SEARCH_PROVIDER=searxng
SEARXNG_BASE_URL=http://localhost:8080

# Opcional: Firecrawl extrai páginas modernas em Markdown.
# Também pode ser usado como provedor de busca.
# FIRECRAWL_API_KEY=sua_chave_firecrawl
# SEARCH_PROVIDER=firecrawl

# Alternativa gratuita sem Docker, menos estável que SearXNG local.
# SEARCH_PROVIDER=ddgs

# Banco vetorial local.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=nvidia_knowledge
# QDRANT_API_KEY=apenas_para_qdrant_cloud

# Embeddings gratuitos e locais por padrão.
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
SPARSE_EMBEDDING_MODEL=Qdrant/bm25

# Alternativa OpenAI. A chave nunca deve ser colocada no código.
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_EMBEDDING_DIMENSIONS=1536
# OPENAI_API_KEY=sua_chave

RAG_TOP_K=20
RAG_TOP_N=5
RERANKER_PROVIDER=lexical
# RERANKER_PROVIDER=bge
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Geração local determinística e fundamentada por padrão.
RAG_GENERATOR_PROVIDER=deterministic
# RAG_GENERATOR_PROVIDER=openai
# RAG_GENERATOR_MODEL=gpt-4o

# Persistência transacional. Use somente no backend.
# O schema nvidia_inception deve estar exposto na Data API do projeto.
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SECRET_KEY=sb_secret_sua_chave_secreta
SUPABASE_TRACE_BUCKET=pipeline-traces

# Protege todos os endpoints /api/v1 e /metrics.
BACKEND_API_KEY=gere-uma-chave-longa-e-aleatoria
